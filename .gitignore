# Python
.venv/
__pycache__/
*.pyc
*.egg-info/
build/
dist/

# Argus output — generated compose projects and secrets (never commit)
generated/
secrets/

# Local Claude Code settings (machine-specific permissions) + runtime state
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Local deployment config (host-specific; the tracked config.yaml is the template)
deploy-config.yaml

# Local environment / secrets — tokens etc. (NEVER commit)
.env
.env.*
*.env
